<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BKK Journal — バンコク情報キュレーション</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+JP:wght@400;700&family=Noto+Sans+JP:wght@400;500&family=Sarabun:wght@400;700&display=swap" rel="stylesheet">
  <style>
    :root{
      --gold:#C9A84C;--gold-lt:#F0D98A;--red:#C0392B;
      --ink:#1A1714;--ink-mid:#3D3730;--ink-lt:#7A6F65;
      --paper:#F7F3ED;--paper-lt:#FDFAF6;--border:#DDD5C8;
      --c-ja:#2C5F2E;--c-priv:#5B2C6F;
      --c-domestic:#1A5276;--c-intl:#6C3483;
      --c-events:#1A6B5A;--c-mall:#8E3A09;
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'Noto Sans JP',sans-serif;background:var(--paper);color:var(--ink);font-size:15px;line-height:1.7}

    /* Header */
    header{background:var(--ink);border-bottom:3px solid var(--gold);padding:0 20px;position:sticky;top:0;z-index:100}
    .header-inner{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;height:58px}
    .site-title{font-family:'Noto Serif JP',serif;font-size:20px;font-weight:700;color:var(--gold);text-decoration:none;letter-spacing:.04em;white-space:nowrap}
    .site-title span{color:#fff;font-weight:400;font-size:12px;margin-left:8px;opacity:.7;vertical-align:middle}
    .updated{font-size:11px;color:#888;font-family:monospace;white-space:nowrap}

    /* Tab bar */
    .tab-bar{background:var(--paper-lt);border-bottom:1px solid var(--border);padding:0 20px;position:sticky;top:58px;z-index:99;overflow-x:auto;-webkit-overflow-scrolling:touch}
    .tab-inner{max-width:1200px;margin:0 auto;display:flex;min-width:max-content}
    .tab-btn{font-size:13px;padding:12px 16px;background:none;border:none;border-bottom:3px solid transparent;cursor:pointer;color:var(--ink-lt);white-space:nowrap;font-family:'Noto Sans JP',sans-serif;transition:color .15s,border-color .15s}
    .tab-btn:hover{color:var(--ink)}
    .tab-btn.active{color:var(--gold);border-bottom-color:var(--gold);font-weight:500}

    main{max-width:1200px;margin:0 auto;padding:24px 20px 64px}
    .view{display:none}.view.active{display:block}

    /* ── カード共通 ── */
    .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:18px}
    .card{background:var(--paper-lt);border:1px solid var(--border);border-radius:4px;overflow:hidden;display:flex;flex-direction:column;transition:transform .15s,box-shadow .15s}
    .card:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(26,23,20,.12)}
    .card-img{width:100%;aspect-ratio:16/9;object-fit:cover;display:block;background:var(--border)}
    .card-ph{width:100%;aspect-ratio:16/9;background:linear-gradient(135deg,#EBE3D8,#D9CEBF);display:flex;align-items:center;justify-content:center;font-size:26px}
    .card-body{padding:14px 16px 18px;display:flex;flex-direction:column;flex:1}
    .card-meta{display:flex;align-items:center;gap:8px;margin-bottom:8px;flex-wrap:wrap}
    .tag{font-size:10px;font-weight:500;padding:2px 6px;border-radius:2px;color:#fff;letter-spacing:.04em}
    .tag-ja_news{background:var(--c-ja)}
    .tag-privilege{background:var(--c-priv)}
    .tag-news_domestic{background:var(--c-domestic)}
    .tag-news_intl{background:var(--c-intl)}
    .tag-events{background:var(--c-events)}
    .tag-mall_events{background:var(--c-mall)}
    .card-date{font-size:11px;color:var(--ink-lt)}
    .card-source{font-size:10px;color:var(--ink-lt);margin-left:auto;font-family:'Sarabun',sans-serif;opacity:.8}
    .card-title{font-family:'Noto Serif JP',serif;font-size:14px;font-weight:700;line-height:1.5;margin-bottom:6px}
    .card-summary{font-size:12px;color:var(--ink-mid);line-height:1.7;flex:1}
    .card-footer{margin-top:12px;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px}
    .card-link{font-size:12px;font-weight:500;color:var(--gold);text-decoration:none;border-bottom:1px solid var(--gold-lt)}
    .card-link:hover{color:var(--red)}
    .card-link::after{content:" →"}
    .ev-badge{font-size:10px;color:var(--c-events);background:#E8F5F1;padding:2px 7px;border-radius:2px}
    .empty{color:var(--ink-lt);font-size:14px;padding:32px 0}

    /* ── ダッシュボード（今日・新着タブ） ── */
    .dash-section{margin-bottom:32px}
    .dash-section h2{font-family:'Noto Serif JP',serif;font-size:17px;font-weight:700;margin-bottom:14px;padding-bottom:8px;border-bottom:2px solid var(--gold);display:flex;align-items:center;gap:8px}
    .dash-section h2 .count{font-size:12px;font-weight:400;color:var(--ink-lt);font-family:'Noto Sans JP',sans-serif}

    /* 今日のイベント：横スクロールカード列 */
    .ev-scroll{display:flex;gap:14px;overflow-x:auto;padding-bottom:8px;-webkit-overflow-scrolling:touch;scrollbar-width:thin}
    .ev-scroll::-webkit-scrollbar{height:4px}
    .ev-scroll::-webkit-scrollbar-track{background:var(--border)}
    .ev-scroll::-webkit-scrollbar-thumb{background:var(--gold-lt);border-radius:2px}
    .ev-card{flex:0 0 220px;background:var(--paper-lt);border:1px solid var(--border);border-radius:4px;overflow:hidden;cursor:pointer;transition:transform .15s,box-shadow .15s}
    .ev-card:hover{transform:translateY(-2px);box-shadow:0 4px 14px rgba(26,23,20,.1)}
    .ev-card-body{padding:12px 14px}
    .ev-card-tag{font-size:9px;padding:2px 6px;border-radius:2px;color:#fff;display:inline-block;margin-bottom:6px}
    .ev-card-title{font-family:'Noto Serif JP',serif;font-size:13px;font-weight:700;line-height:1.4;margin-bottom:4px}
    .ev-card-date{font-size:11px;color:var(--ink-lt)}
    .ev-card-venue{font-size:11px;color:var(--ink-lt);margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
    .ev-none{color:var(--ink-lt);font-size:13px;padding:16px 0}

    /* ── カレンダービュー ── */
    .cal-container{width:100%}
    .cal-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
    .cal-month{font-family:'Noto Serif JP',serif;font-size:18px;font-weight:700}
    .cal-navs{display:flex;gap:6px}
    .cal-navs button{background:none;border:1px solid var(--border);border-radius:4px;padding:4px 12px;cursor:pointer;font-size:12px;color:var(--ink-mid);font-family:'Noto Sans JP',sans-serif}
    .cal-navs button:hover{background:var(--border)}
    .cal-box{background:var(--paper-lt);border:1px solid var(--border);border-radius:4px;overflow:hidden;width:100%}
    .cal-dow{display:grid;grid-template-columns:repeat(7,1fr);background:var(--ink)}
    .cal-dow span{color:var(--gold-lt);font-size:11px;font-weight:500;text-align:center;padding:6px 0}
    .cal-dow span:first-child{color:#e88}
    .cal-dow span:last-child{color:#aaf}
    .cal-cells{display:grid;grid-template-columns:repeat(7,1fr);width:100%}
    .cell{min-height:64px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);padding:4px 3px;overflow:hidden}
    .cell:nth-child(7n){border-right:none}
    .cell.other{background:#f0ebe4;opacity:.5}
    .cell.today{background:#FFF8E8}
    .cell.has-ev{cursor:pointer}.cell.has-ev:hover{background:#F5EFE6}
    .cell-num{font-size:11px;color:var(--ink-lt);display:block;margin-bottom:2px}
    .cell.today .cell-num{color:var(--gold);font-weight:700}
    .cell.today .cell-num::after{content:'●';font-size:5px;margin-left:2px;vertical-align:middle}
    .cell-sun .cell-num{color:#c55}
    .cell-sat .cell-num{color:#55c}
    .ev-pill{display:block;font-size:9px;padding:1px 3px;border-radius:2px;color:#fff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-top:1px;cursor:pointer;line-height:1.4}
    .ev-pill.ev-events{background:var(--c-events)}
    .ev-pill.ev-mall_events{background:var(--c-mall)}
    .ev-more{font-size:9px;color:var(--ink-lt);margin-top:1px;display:block}

    /* カレンダー下のイベントカード一覧 */
    .cal-ev-list{margin-top:24px}
    .cal-ev-list h3{font-family:'Noto Serif JP',serif;font-size:16px;font-weight:700;margin-bottom:14px;padding-bottom:8px;border-bottom:1px solid var(--border)}
    .cal-ev-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:14px}
    .cal-ev-card{background:var(--paper-lt);border:1px solid var(--border);border-radius:4px;padding:14px;cursor:pointer;transition:box-shadow .15s}
    .cal-ev-card:hover{box-shadow:0 4px 14px rgba(26,23,20,.1)}
    .cev-tag{font-size:9px;padding:1px 6px;border-radius:2px;color:#fff;display:inline-block;margin-bottom:6px}
    .cev-title{font-family:'Noto Serif JP',serif;font-size:13px;font-weight:700;line-height:1.4;margin-bottom:4px}
    .cev-date{font-size:11px;color:var(--ink-lt);margin-bottom:2px}
    .cev-venue{font-size:11px;color:var(--ink-lt)}

    /* モーダル */
    .modal-bg{position:fixed;inset:0;background:rgba(26,23,20,.55);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
    .modal-bg.open{display:flex}
    .modal{background:var(--paper-lt);border-radius:6px;max-width:520px;width:100%;max-height:80vh;overflow-y:auto;padding:24px;position:relative}
    .modal-close{position:absolute;top:12px;right:14px;background:none;border:none;font-size:22px;cursor:pointer;color:var(--ink-lt)}
    .modal-close:hover{color:var(--ink)}
    .m-tag{font-size:11px;padding:2px 8px;border-radius:2px;color:#fff;display:inline-block;margin-bottom:10px}
    .m-title{font-family:'Noto Serif JP',serif;font-size:17px;font-weight:700;line-height:1.5;margin-bottom:12px}
    .m-meta{display:flex;flex-direction:column;gap:5px;margin-bottom:12px;font-size:13px;color:var(--ink-mid)}
    .m-meta span{display:flex;gap:6px}
    .m-summary{font-size:14px;line-height:1.8;color:var(--ink-mid);margin-bottom:16px}
    .m-link{font-size:13px;font-weight:500;color:var(--gold);border-bottom:1px solid var(--gold-lt);text-decoration:none}
    .m-link:hover{color:var(--red)}

    footer{text-align:center;padding:20px;font-size:11px;color:var(--ink-lt);border-top:1px solid var(--border)}
    @media(max-width:600px){.grid{grid-template-columns:1fr}.site-title span{display:none}}
  </style>
</head>
<body>

<header>
  <div class="header-inner">
    <a class="site-title" href="#">BKK Journal<span>バンコク情報キュレーション</span></a>
    <div class="updated">{{ updated_at }}</div>
  </div>
</header>

<div class="tab-bar">
  <div class="tab-inner">
    <button class="tab-btn active" onclick="switchTab('dashboard',this)">🏠 今日・新着</button>
    {% for cat, label in category_labels.items() %}
    <button class="tab-btn" onclick="switchTab('{{ cat }}',this)">
      {{ label }}{% if by_cat.get(cat) %}（{{ by_cat[cat]|length }}）{% else %}（0）{% endif %}
    </button>
    {% endfor %}
    <button class="tab-btn" onclick="switchTab('calendar',this)">📅 カレンダー</button>
  </div>
</div>

<main>

  {# ── ダッシュボード ── #}
  <div class="view active" id="view-dashboard">

    <div class="dash-section">
      <h2>📅 今日のイベント <span class="count" id="today-count"></span></h2>
      <div class="ev-scroll" id="today-events-row">
        <div class="ev-none">イベント情報を読み込み中…</div>
      </div>
    </div>

    <div class="dash-section">
      <h2>🔔 新着記事 <span class="count" id="recent-count"></span></h2>
      <div class="grid" id="recent-grid">
        {% for a in recent_articles_json | safe %}{% endfor %}
      </div>
    </div>

  </div>

  {# ── カテゴリタブ ── #}
  {% for cat, label in category_labels.items() %}
  <div class="view" id="view-{{ cat }}">
    {% set articles = by_cat.get(cat, []) %}
    {% if articles %}
    <div class="grid">
      {% for a in articles %}
      <article class="card">
        {% if a.image_url %}<img class="card-img" src="{{ a.image_url }}" alt="" loading="lazy" onerror="this.style.display='none'">
        {% else %}<div class="card-ph">{{ '🇹🇭' if cat=='news_domestic' else '🌏' if cat=='news_intl' else '🎉' if cat=='events' else '🏬' if cat=='mall_events' else '🎖️' if cat=='privilege' else '📰' }}</div>{% endif %}
        <div class="card-body">
          <div class="card-meta">
            <span class="tag tag-{{ a.category }}">{{ label }}</span>
            <span class="card-date">{{ a.date_ja }}</span>
            <span class="card-source">{{ a.source_name }}</span>
          </div>
          <h2 class="card-title">{{ a.title_ja if a.get('title_ja') else a.title_original }}</h2>
          <p class="card-summary">{{ a.summary_ja if a.get('summary_ja') else a.summary_original }}</p>
          <div class="card-footer">
            <a class="card-link" href="{{ a.url }}" target="_blank" rel="noopener">元記事</a>
            {% if a.event_start %}<span class="ev-badge">📅 {{ a.event_start[:10] }}{% if a.event_end %} 〜 {{ a.event_end[:10] }}{% endif %}</span>{% endif %}
          </div>
        </div>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p class="empty">記事がありません。次回更新をお待ちください。</p>
    {% endif %}
  </div>
  {% endfor %}

  {# ── カレンダービュー ── #}
  <div class="view" id="view-calendar">
    <div class="cal-container">
      <div class="cal-head">
        <div class="cal-month" id="cal-label"></div>
        <div class="cal-navs">
          <button onclick="moveCal(-1)">‹ 前月</button>
          <button onclick="moveCal(0)">今月</button>
          <button onclick="moveCal(1)">次月 ›</button>
        </div>
      </div>
      <div class="cal-box">
        <div class="cal-dow"><span>日</span><span>月</span><span>火</span><span>水</span><span>木</span><span>金</span><span>土</span></div>
        <div class="cal-cells" id="cal-cells"></div>
      </div>
      <div class="cal-ev-list">
        <h3 id="cal-ev-list-title">今月のイベント</h3>
        <div class="cal-ev-grid" id="cal-ev-grid"></div>
      </div>
    </div>
  </div>

</main>

<div class="modal-bg" id="modal" onclick="if(event.target===this)closeModal()">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">×</button>
    <div id="m-tag" class="m-tag"></div>
    <div id="m-title" class="m-title"></div>
    <div id="m-meta" class="m-meta"></div>
    <div id="m-summary" class="m-summary"></div>
    <a id="m-link" class="m-link" target="_blank" rel="noopener">元記事を読む →</a>
  </div>
</div>

<footer>BKK Journal — タイ情報を日本語でお届け &nbsp;|&nbsp; 6時間ごと自動更新</footer>

<script>
const EV_ARTICLES    = {{ ev_json | safe }};
const TODAY_EVENTS   = {{ todays_events_json | safe }};
const RECENT_ARTICLES= {{ recent_articles_json | safe }};
const TODAY_STR      = "{{ today_str }}";

const CAT_COLORS = {
  events:'#1A6B5A', mall_events:'#8E3A09',
  news_domestic:'#1A5276', news_intl:'#6C3483',
  ja_news:'#2C5F2E', privilege:'#5B2C6F'
};
const CAT_NAMES = {
  events:'イベント・祭り', mall_events:'モールイベント',
  news_domestic:'国内ニュース', news_intl:'国際ニュース',
  ja_news:'日本語サイト', privilege:'Thailand Privilege'
};

// ── タブ切り替え ─────────────────────────────────────────────────
function switchTab(id, btn) {
  document.querySelectorAll('.view').forEach(v=>v.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('view-'+id).classList.add('active');
  btn.classList.add('active');
  if(id==='calendar') renderCal();
}

// ── ダッシュボード初期化 ─────────────────────────────────────────
(function initDashboard(){
  // 今日のイベント
  const row = document.getElementById('today-events-row');
  const cnt = document.getElementById('today-count');
  cnt.textContent = TODAY_EVENTS.length+'件';
  if(TODAY_EVENTS.length===0){
    row.innerHTML='<div class="ev-none">本日のイベント情報はありません</div>';
  } else {
    row.innerHTML='';
    TODAY_EVENTS.forEach(a=>{
      const color=CAT_COLORS[a.category]||'#888';
      const name=CAT_NAMES[a.category]||a.category;
      const el=document.createElement('div');
      el.className='ev-card';
      el.onclick=()=>openModal(a);
      el.innerHTML=
        `<div class="ev-card-body">
          <span class="ev-card-tag" style="background:${color}">${name}</span>
          <div class="ev-card-title">${a.title_ja||a.title_original}</div>
          <div class="ev-card-date">📅 ${fmtRange(a.event_start,a.event_end)}</div>
          ${a.event_venue?`<div class="ev-card-venue">📍 ${a.event_venue}</div>`:''}
        </div>`;
      row.appendChild(el);
    });
  }

  // 新着記事グリッド
  const grid=document.getElementById('recent-grid');
  const rcnt=document.getElementById('recent-count');
  rcnt.textContent=RECENT_ARTICLES.length+'件';
  grid.innerHTML='';
  RECENT_ARTICLES.forEach(a=>{
    const color=CAT_COLORS[a.category]||'#888';
    const name=CAT_NAMES[a.category]||a.category;
    const el=document.createElement('article');
    el.className='card';
    const title=a.title_ja||a.title_original||'';
    const summary=a.summary_ja||a.summary_original||'';
    const evBadge=a.event_start?`<span class="ev-badge">📅 ${a.event_start.slice(0,10)}</span>`:'';
    el.innerHTML=
      `<div class="card-ph" style="font-size:22px">${
        a.category==='news_domestic'?'🇹🇭':a.category==='news_intl'?'🌏':
        a.category==='events'?'🎉':a.category==='mall_events'?'🏬':
        a.category==='privilege'?'🎖️':'📰'
      }</div>
      <div class="card-body">
        <div class="card-meta">
          <span class="tag" style="background:${color}">${name}</span>
          <span class="card-source">${a.source_name||''}</span>
        </div>
        <h2 class="card-title">${title}</h2>
        <p class="card-summary">${summary.slice(0,120)}${summary.length>120?'…':''}</p>
        <div class="card-footer">
          <a class="card-link" href="${a.url}" target="_blank" rel="noopener">元記事</a>
          ${evBadge}
        </div>
      </div>`;
    grid.appendChild(el);
  });
})();

// ── カレンダー ────────────────────────────────────────────────────
let cY, cM;
(function(){const n=new Date();cY=n.getFullYear();cM=n.getMonth();})();

function moveCal(d){
  if(d===0){const n=new Date();cY=n.getFullYear();cM=n.getMonth();}
  else{cM+=d;if(cM>11){cM=0;cY++;}if(cM<0){cM=11;cY--;}}
  renderCal();
}

function evByDay(){
  const map={};
  EV_ARTICLES.forEach(a=>{
    if(!a.event_start)return;
    const s=new Date(a.event_start);
    if(isNaN(s))return;
    const e=a.event_end?new Date(a.event_end):s;
    const lo=new Date(cY,cM,1),hi=new Date(cY,cM+1,0);
    let cur=new Date(Math.max(s,lo));
    const end2=new Date(Math.min(e,hi));
    while(cur<=end2){
      const k=cur.getDate();
      (map[k]=map[k]||[]).push(a);
      cur.setDate(cur.getDate()+1);
    }
  });
  return map;
}

function renderCal(){
  const MN=['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
  document.getElementById('cal-label').textContent=cY+'年 '+MN[cM];
  const today=new Date();
  const fd=new Date(cY,cM,1).getDay();
  const dim=new Date(cY,cM+1,0).getDate();
  const dip=new Date(cY,cM,0).getDate();
  const map=evByDay();
  const grid=document.getElementById('cal-cells');
  grid.innerHTML='';
  const total=Math.ceil((fd+dim)/7)*7;
  for(let i=0;i<total;i++){
    let day,thisM=true;
    if(i<fd){day=dip-fd+i+1;thisM=false;}
    else if(i>=fd+dim){day=i-fd-dim+1;thisM=false;}
    else{day=i-fd+1;}
    const dow=i%7;
    const cell=document.createElement('div');
    let cls='cell';
    if(!thisM)cls+=' other';
    else if(today.getFullYear()===cY&&today.getMonth()===cM&&today.getDate()===day)cls+=' today';
    if(dow===0)cls+=' cell-sun';
    if(dow===6)cls+=' cell-sat';
    if(thisM&&map[day])cls+=' has-ev';
    cell.className=cls;
    const num=document.createElement('span');
    num.className='cell-num';num.textContent=day;cell.appendChild(num);
    if(thisM&&map[day]){
      const evs=map[day];
      evs.slice(0,2).forEach(a=>{
        const p=document.createElement('span');
        p.className='ev-pill ev-'+a.category;
        p.textContent=a.title_ja||a.title_original;
        p.onclick=ev=>{ev.stopPropagation();openModal(a);};
        cell.appendChild(p);
      });
      if(evs.length>2){
        const m=document.createElement('span');
        m.className='ev-more';m.textContent='+'+(evs.length-2)+'件';
        cell.appendChild(m);
      }
      cell.onclick=()=>showEvList(day,evs);
    }
    grid.appendChild(cell);
  }
  showMonthEvList();
}

function showMonthEvList(){
  const evs=EV_ARTICLES.filter(a=>{
    if(!a.event_start)return false;
    const d=new Date(a.event_start);
    return d.getFullYear()===cY&&d.getMonth()===cM;
  }).sort((a,b)=>new Date(a.event_start)-new Date(b.event_start));
  const MN=['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
  document.getElementById('cal-ev-list-title').textContent=
    cY+'年'+MN[cM]+'のイベント（'+evs.length+'件）';
  renderEvGrid(evs);
}

function showEvList(day,evs){
  const MN=['1月','2月','3月','4月','5月','6月','7月','8月','9月','10月','11月','12月'];
  document.getElementById('cal-ev-list-title').textContent=
    MN[cM]+day+'日のイベント';
  renderEvGrid(evs);
}

function renderEvGrid(evs){
  const grid=document.getElementById('cal-ev-grid');
  if(!evs.length){grid.innerHTML='<div class="empty">イベントなし</div>';return;}
  grid.innerHTML='';
  evs.forEach(a=>{
    const color=CAT_COLORS[a.category]||'#888';
    const name=CAT_NAMES[a.category]||a.category;
    const el=document.createElement('div');
    el.className='cal-ev-card';el.onclick=()=>openModal(a);
    el.innerHTML=
      `<span class="cev-tag" style="background:${color}">${name}</span>
      <div class="cev-title">${a.title_ja||a.title_original}</div>
      <div class="cev-date">📅 ${fmtRange(a.event_start,a.event_end)}</div>
      ${a.event_venue?`<div class="cev-venue">📍 ${a.event_venue}</div>`:''}`;
    grid.appendChild(el);
  });
}

// ── モーダル ─────────────────────────────────────────────────────
function openModal(a){
  const color=CAT_COLORS[a.category]||'#888';
  const name=CAT_NAMES[a.category]||a.category;
  document.getElementById('m-tag').textContent=name;
  document.getElementById('m-tag').style.background=color;
  document.getElementById('m-title').textContent=a.title_ja||a.title_original;
  let meta='';
  if(a.event_start)meta+=`<span>📅 ${fmtRange(a.event_start,a.event_end)}</span>`;
  if(a.event_venue)meta+=`<span>📍 ${a.event_venue}</span>`;
  if(a.event_admission)meta+=`<span>🎟 ${a.event_admission}</span>`;
  document.getElementById('m-meta').innerHTML=meta;
  document.getElementById('m-summary').textContent=a.summary_ja||a.summary_original||'';
  document.getElementById('m-link').href=a.url;
  document.getElementById('modal').classList.add('open');
}
function closeModal(){document.getElementById('modal').classList.remove('open');}
document.addEventListener('keydown',e=>{if(e.key==='Escape')closeModal();});

function fmtDate(s){
  const d=new Date(s);if(isNaN(d))return '日程未定';
  return (d.getMonth()+1)+'月'+d.getDate()+'日（'+'日月火水木金土'[d.getDay()]+'）';
}
function fmtRange(s,e){
  if(!s)return '日程未定';
  const a=fmtDate(s);if(!e)return a;
  const b=fmtDate(e);return a===b?a:a+' 〜 '+b;
}
</script>
</body>
</html>
